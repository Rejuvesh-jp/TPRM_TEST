# ─────────────────────────────────────────────────────────
# TPRM AI Assessment Platform — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# Never commit .env to source control.

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=tprm_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=tprm_db

# ── Application ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_run_python_to_generate

# Host/port the app listens on
TPRM_HOST=0.0.0.0
TPRM_PORT=8085
TPRM_DEBUG=false

# ── Azure OpenAI ────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME_your_openai_or_azure_key
OPENAI_MODEL=gpt-4o

# ── Azure AD (SSO / Graph mail) ─────────────────────────
CLIENT_ID=CHANGE_ME_azure_app_client_id
CLIENT_SECRET=CHANGE_ME_azure_app_client_secret
TENANT_ID=CHANGE_ME_azure_tenant_id
SENDER_EMAIL=noreply@yourdomain.com
